# WARNING: Replace all CHANGEME placeholders with secure production values.

APP_NAME="Diplomarbeit Massenbewegungen"
APP_ENV=production
APP_KEY=CHANGEME
APP_DEBUG=false
APP_URL=CHANGEME

APP_LOCALE=de
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=CHANGEME
DB_USERNAME=CHANGEME
DB_PASSWORD=CHANGEME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

FILESYSTEM_DISK=local
CACHE_STORE=database

VITE_APP_NAME="${APP_NAME}"
