{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "ederjos/mass-defo",
    "description": "Mass Defo - Webplattform zur Visualisierung von Massenbewegungen",
    "type": "project",
    "homepage": "https://github.com/ederjos/Diplomarbeit_Massenbewegungen",
    "license": "MIT",
    "authors": [
        {
            "name": "Josef Eder",
            "email": "josef@josefeder.de"
        },
        {
            "name": "Simon Pointner"
        }
    ],
    "require": {
        "php": "^8.5",
        "clickbar/laravel-magellan": "^2.1.0",
        "inertiajs/inertia-laravel": "^3.0.1",
        "laravel/fortify": "^1.36.2",
        "laravel/framework": "^13.3.0",
        "laravel/tinker": "^3.0.0",
        "laravel/wayfinder": "^0.1.15"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "laravel/boost": "^2.4.1",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.29.0",
        "laravel/sail": "^1.56.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.2",
        "pestphp/pest": "^4.4.5",
        "pestphp/pest-plugin-laravel": "^4.1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "lint": [
            "pint"
        ],
        "lint:check": [
            "pint --test"
        ],
        "test": [
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    }
}
